{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@ayan/sdk": ["hub/sdk/service-sdk/src"],
      "@ayan/types": ["hub/sdk/types"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
