# ─────────────────────────────────────────────
# Agent-Ayan Unified Intelligence Hub
# Environment Configuration
# ─────────────────────────────────────────────

# ── Infrastructure ──
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=agent_ayan_db
POSTGRES_USER=ayan_admin

REDIS_PASSWORD=changeme_in_production

# ── Auth ──
JWT_SECRET=changeme_32_char_random_secret_here
NEXTAUTH_SECRET=changeme_another_secret_here

# ── Keycloak ──
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_in_production
KEYCLOAK_REALM=ayan
KEYCLOAK_URL=http://hub-keycloak:8080

# ── LiveKit ──
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_WS_URL=ws://localhost:14780

# ── MinIO (Object Storage) ──
MINIO_ROOT_USER=ayan_minio_admin
MINIO_ROOT_PASSWORD=changeme_in_production
MINIO_ENDPOINT=http://hub-minio:9000

# ── Hub Services (internal) ──
HUB_GATEWAY_URL=http://hub-gateway:3000
HUB_CONTROL_PLANE_URL=http://hub-control-plane:3000
HUB_WEBSOCKET_URL=http://hub-websocket:3000
HUB_SESSION_MANAGER_URL=ws://hub-session-manager:8181
HUB_AI_VISION_URL=http://hub-ai-vision:8001
HUB_AI_AUDIO_URL=http://hub-ai-audio:8002
HUB_AI_BEHAVIOR_URL=http://hub-ai-behavior:8003
HUB_AGENT_RUNTIME_URL=http://hub-agent-runtime:3000
HUB_GATEKEEPER_URL=http://hub-gatekeeper:3000
HUB_GHOST_PROCTOR_URL=http://hub-ghost-proctor:3000
HUB_DECISION_SUPPORT_URL=http://hub-decision-support:3000
HUB_LEARNING_ENGINE_URL=http://hub-learning-engine:3000

# ── Database URLs (container-internal) ──
DATABASE_URL=postgresql://ayan_admin:changeme_in_production@hub-postgres:5432/agent_ayan_db
REDIS_URL=redis://:changeme_in_production@hub-redis:6379

# ── Frontend (browser-facing) ──
NEXT_PUBLIC_HUB_GATEWAY_URL=http://localhost:14001
NEXT_PUBLIC_HUB_WEBSOCKET_URL=ws://localhost:14801
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:14780
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:14080

# ── LLM / AI ──
OLLAMA_URL=http://hub-ollama:11434
LLM_MODEL=mistral:7b
QDRANT_URL=http://hub-qdrant:6333

# ── Playback Service ──
HUB_PLAYBACK_URL=http://hub-playback:3004

# ── Monitoring (enable with: docker compose --profile monitoring up) ──
GRAFANA_ADMIN_PASSWORD=changeme_in_production

# ── Node ──
NODE_ENV=development
