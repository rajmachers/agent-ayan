# Service Configuration
NODE_ENV=development
PORT=3004
HOST=0.0.0.0
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/agent_proctor
REDIS_URL=redis://localhost:6379

# Storage Configuration
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recordings
MINIO_USE_SSL=false

# AWS S3 (alternative to MinIO)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=agent-proctor-recordings

# LiveKit Configuration
LIVEKIT_WS_URL=wss://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# AI Services Configuration
AI_VISION_URL=http://localhost:8001
AI_AUDIO_URL=http://localhost:8002
AI_BEHAVIOR_URL=http://localhost:8003

# Processing Configuration
MAX_CONCURRENT_ANALYSIS=3
CHUNK_DURATION_SECONDS=30
ANALYSIS_BATCH_SIZE=5
MAX_RECORDING_SIZE_GB=10

# Indexing Configuration
INDEXING_ENABLED=true
REAL_TIME_ANALYSIS=true
VIOLATION_THRESHOLD=0.6
TIMESTAMP_PRECISION_MS=1000

# API Configuration
CORS_ORIGINS=http://localhost:3001,http://localhost:3003
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_ENABLED=true

# Audit Configuration
AUDIT_RETENTION_DAYS=90
REPORT_GENERATION_TIMEOUT=300
VIDEO_PROCESSING_TIMEOUT=600
THUMBNAIL_GENERATION=true

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
PERFORMANCE_MONITORING=true