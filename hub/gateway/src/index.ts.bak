import express from 'express';
import cors from 'cors';
import helmet from 'helmet';
import compression from 'compression';
import { createServer } from 'http';
import { WebSocketServer, WebSocket } from 'ws';

import { config } from './config';
import { logger } from './utils/logger';
import { jwtAuthMiddleware } from './middleware/auth';
import { errorHandler } from './middleware/error';
import { rateLimitMiddleware } from './middleware/rateLimit';
import { requestLogger } from './middleware/requestLogger';
import { dbPool } from './utils/database';
import { redisClient } from './utils/redis';

// Route imports
import { healthRoutes } from './routes/health';
import { authRoutes } from './routes/auth';
import { organizationRoutes } from './routes/organizations';
import { examRoutes } from './routes/exams';
import { sessionRoutes } from './routes/sessions';
import { livekitRoutes } from './routes/livekit';
import { webhookRoutes } from './routes/webhooks';

// Extend WebSocket interface to add custom properties\ninterface ExtendedWebSocket extends WebSocket {\n  sessionId?: string;\n  userId?: string;\n  isAlive?: boolean;\n}\n\nconst app = express();
const server = createServer(app);
const wss = new WebSocketServer({ server });

// Trust proxy for proper IP forwarding
app.set('trust proxy', 1);

// Security middleware
app.use(helmet({
  crossOriginEmbedderPolicy: false, // Allow iframe embedding
  contentSecurityPolicy: {
    directives: {
      defaultSrc: ["'self'"],
      styleSrc: ["'self'", "'unsafe-inline'"],
      scriptSrc: ["'self'"],
      imgSrc: ["'self'", "data:", "https:"],
      connectSrc: ["'self'", "ws:", "wss:"],
      frameAncestors: ["'self'", "https:"], // Allow embedding
    },
  },
}));

// CORS configuration
app.use(cors({
  origin: config.cors.origins,
  credentials: true,
  optionsSuccessStatus: 200,
}));

// Compression and parsing
app.use(compression());
app.use(express.json({ limit: '10mb' }));
app.use(express.urlencoded({ extended: true, limit: '10mb' }));

// Request logging
app.use(requestLogger);

// Rate limiting
app.use(rateLimitMiddleware);

// Health check (no auth required)
app.use('/health', healthRoutes);
app.use('/api/v1/health', healthRoutes);

// Webhook endpoints (no auth required, but validated)
app.use('/webhooks', webhookRoutes);

// JWT Authentication middleware for API routes
app.use('/api/v1', jwtAuthMiddleware);

// API Routes (all require authentication)
app.use('/api/v1/auth', authRoutes);
app.use('/api/v1/organizations', organizationRoutes);
app.use('/api/v1/exams', examRoutes);
app.use('/api/v1/sessions', sessionRoutes);
app.use('/api/v1/livekit', livekitRoutes);

// Error handling
app.use(errorHandler);

// WebSocket connection handling
wss.on('connection', (ws: ExtendedWebSocket, request) => {
  logger.info('WebSocket connection established', {
    ip: request.socket.remoteAddress,
    userAgent: request.headers['user-agent'],
  });

  ws.on('message', (message: Buffer) => {
    try {
      const data = JSON.parse(message.toString());
      logger.debug('WebSocket message received', { data });
      
      // Handle different message types
      switch (data.type) {
        case 'subscribe_session':
          // Subscribe to session events
          ws.sessionId = data.sessionId;
          ws.send(JSON.stringify({
            type: 'subscribed',
            sessionId: data.sessionId,
          }));
          break;
        case 'ping':
          ws.send(JSON.stringify({ type: 'pong' }));
          break;
        default:
          logger.warn('Unknown WebSocket message type', { type: data.type });
      }
    } catch (error) {
      logger.error('Error processing WebSocket message', { error, message: message.toString() });
    }
  });

  ws.on('close', (code: number, reason: Buffer) => {
    logger.info('WebSocket connection closed', {
      code,
      reason: reason.toString(),
      sessionId: (ws as any).sessionId,
    });
  });

  ws.on('error', (error: Error) => {
    logger.error('WebSocket error', { error });
  });
});

// Graceful shutdown
process.on('SIGINT', async () => {
  logger.info('Received SIGINT, starting graceful shutdown');
  
  server.close(async () => {
    logger.info('HTTP server closed');
    
    try {
      await dbPool.end();
      logger.info('Database pool closed');
    } catch (error) {
      logger.error('Error closing database pool', { error });
    }
    
    try {
      await redisClient.quit();
      logger.info('Redis connection closed');
    } catch (error) {
      logger.error('Error closing Redis connection', { error });
    }
    
    process.exit(0);
  });
});

// Start server
server.listen(config.port, () => {
  logger.info(`🚀 Ayan.ai API Gateway started on port ${config.port}`, {
    environment: config.environment,
    version: process.env['npm_package_version'] || '1.0.0',
  });
});

export { app, server, wss };